# Auto-detect text files and normalise line endings to LF
* text=auto eol=lf

# Shell scripts must stay LF
*.sh text eol=lf

# Text formats
*.md text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

# Binary — treat as binary, no diff
*.png binary
*.jpg binary
*.ico binary

# Squad: union merge for append-only team state files
.squad/decisions.md merge=union
.squad/agents/*/history.md merge=union
.squad/log/** merge=union
.squad/orchestration-log/** merge=union
